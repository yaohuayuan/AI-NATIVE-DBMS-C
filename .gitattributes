# Use LF line endings in repository and working tree.
* text=auto eol=lf

# Source files
*.c     text eol=lf
*.h     text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf

# Scripts
*.ps1   text eol=lf
*.sh    text eol=lf

# Config files
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf

# Binary files
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.7z    binary
*.exe   binary
*.dll   binary
*.lib   binary
*.a     binary