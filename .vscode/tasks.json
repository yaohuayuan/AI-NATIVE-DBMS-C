{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake: configure debug",
      "type": "shell",
      "command": "cmake --preset mingw-debug",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "cmake: build debug",
      "type": "shell",
      "command": "cmake --build --preset mingw-debug-build",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "cmake: test debug",
      "type": "shell",
      "command": "ctest --preset mingw-debug-test",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "cmake: configure + build + test debug",
      "dependsOrder": "sequence",
      "dependsOn": [
        "cmake: configure debug",
        "cmake: build debug",
        "cmake: test debug"
      ],
      "problemMatcher": []
    },
    {
      "label": "run: aidb",
      "type": "shell",
      "command": "bin\\debug\\aidb.exe",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "dependsOn": [
        "cmake: build debug"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "clean: build and bin",
      "type": "shell",
      "command": "if exist build rmdir /s /q build && if exist bin rmdir /s /q bin",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "rebuild: clean + configure + build + test debug",
      "dependsOrder": "sequence",
      "dependsOn": [
        "clean: build and bin",
        "cmake: configure debug",
        "cmake: build debug",
        "cmake: test debug"
      ],
      "problemMatcher": []
    }
  ]
}