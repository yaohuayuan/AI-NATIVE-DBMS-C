{
  "version": 4,
  "configurations": [
    {
      "name": "Win32-MinGW",
      "compilerPath": "gcc.exe",
      "intelliSenseMode": "windows-gcc-x64",
      "cStandard": "c17",
      "cppStandard": "c++17",
      "includePath": [
        "${workspaceFolder}/include",
        "${workspaceFolder}/src",
        "${workspaceFolder}/tests",
        "${workspaceFolder}/**"
      ],
      "defines": [
        "_DEBUG",
        "AIDB_DEBUG"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}/include",
          "${workspaceFolder}/src",
          "${workspaceFolder}/tests"
        ],
        "limitSymbolsToIncludedHeaders": true
      }
    }
  ]
}