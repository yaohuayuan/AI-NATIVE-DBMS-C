{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug aidb.exe - integrated",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}\\bin\\debug\\aidb.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "avoidWindowsConsoleRedirection": false,
      "MIMode": "gdb",
      "miDebuggerPath": "gdb.exe",
      "preLaunchTask": "cmake: build debug",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
